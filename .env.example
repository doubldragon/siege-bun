# Web deployment (Turso)
DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Desktop / local dev (bun:sqlite — leave DATABASE_URL unset or use file: prefix)
# DATABASE_URL=file:./siege.db

# Server
PORT=3000
BETTER_AUTH_SECRET=change-me-to-a-random-secret
APP_URL=http://localhost:5173

# Web (exposed to browser via Vite — auth client uses this to bypass Vite proxy)
VITE_API_URL=http://localhost:3000
